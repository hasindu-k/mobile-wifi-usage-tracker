<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/title_dashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data Usage Monitor"
            android:textColor="@color/text_main"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_custom_date"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_my_calendar"
            app:layout_constraintBottom_toBottomOf="@id/title_dashboard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/title_dashboard"
            app:tint="@color/primary" />

        <!-- History Filter Chips -->
        <HorizontalScrollView
            android:id="@+id/scroll_filters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/title_dashboard">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_today"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Today" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_yesterday"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yesterday" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_week"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Week" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_month"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Month" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Today Total Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_today_total"
            style="@style/DashboardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/scroll_filters">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today Total"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_today_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="2.4 GB used today"
                    android:textColor="@color/text_main"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Wi-Fi vs Mobile Cards -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_wifi_today"
            style="@style/DashboardCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@+id/card_mobile_today"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_today_total">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/label_wifi_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wi-Fi Today"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />


                <TextView
                    android:id="@+id/tv_wifi_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="1.8 GB"
                    android:textColor="@color/wifi_blue"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_mobile_today"
            style="@style/DashboardCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@id/card_wifi_today"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_wifi_today"
            app:layout_constraintTop_toTopOf="@id/card_wifi_today">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/label_mobile_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Today"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />


                <TextView
                    android:id="@+id/tv_mobile_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="600 MB"
                    android:textColor="@color/mobile_green"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Monthly Cards -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_monthly_wifi"
            style="@style/DashboardCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@+id/card_monthly_mobile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_wifi_today">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Wi-Fi"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_monthly_wifi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="42.5 GB"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_monthly_mobile"
            style="@style/DashboardCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@id/card_monthly_wifi"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_monthly_wifi"
            app:layout_constraintTop_toTopOf="@id/card_monthly_wifi">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Mobile"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_monthly_mobile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="8.3 GB"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hourly Usage Chart Section -->
        <TextView
            android:id="@+id/label_hourly_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Hourly Usage Today"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_monthly_wifi" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_chart"
            style="@style/DashboardCard"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/label_hourly_usage">

            <LinearLayout
                android:id="@+id/chart_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:padding="16dp">
                <!-- Bars will be added programmatically or static for now -->
                <View android:id="@+id/bar1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="40dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" android:backgroundTint="@color/primary" />
                <View android:id="@+id/bar2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="60dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" />
                <View android:id="@+id/bar3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="120dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" />
                <View android:id="@+id/bar4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="80dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" />
                <View android:id="@+id/bar5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="150dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" />
                <View android:id="@+id/bar6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="100dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" />
                <View android:id="@+id/bar7" android:layout_width="0dp" android:layout_weight="1" android:layout_height="130dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" />
                <View android:id="@+id/bar8" android:layout_width="0dp" android:layout_weight="1" android:layout_height="180dp" android:background="@color/chart_bar" android:layout_margin="2dp" android:clickable="true" android:focusable="true" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Wi-Fi vs Mobile Comparison -->
        <TextView
            android:id="@+id/label_comparison"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Wi-Fi vs Mobile Today"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_chart" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_comparison"
            style="@style/DashboardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/label_comparison">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_comparison"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="75"
                    app:indicatorColor="@color/wifi_blue"
                    app:trackColor="@color/mobile_green"
                    app:trackThickness="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_wifi_percentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Wi-Fi: 75%"
                        android:textColor="@color/wifi_blue"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_mobile_percentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile: 25%"
                        android:textColor="@color/mobile_green"
                        android:textStyle="bold" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Peak Usage Card -->
        <TextView
            android:id="@+id/label_peak_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Peak Usage Time Today"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_comparison" />


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_peak_usage"
            style="@style/DashboardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/label_peak_usage">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wi-Fi"
                    android:textColor="@color/wifi_blue"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_peak_wifi_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8:00 PM - 9:00 PM"
                    android:textColor="@color/text_main"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tv_peak_wifi_usage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="950 MB used"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />


                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Data"
                    android:textColor="@color/mobile_green"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_peak_mobile_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2:00 PM - 3:00 PM"
                    android:textColor="@color/text_main"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tv_peak_mobile_usage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120 MB used"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
